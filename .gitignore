# ============================================================
# STITCH2ELEMENTOR — .gitignore
# REGLA: Todo lo que sea específico de un cliente va aquí.
# ============================================================

# ── Configuración de credenciales (NUNCA commitear) ──────────
mcp_config.json
.env
pipeline_state.json
design_system.json
temp_vars.txt
screen_map.json

# ── Datos privados del cliente (NUNCA commitear) ─────────────
INFO_BrandBook/
INFO_BrandBook_*/
v9_images_temp/
assets_originales_backup/
stitch_html/
homepage_stitch.html
INVENTARIO*/
IMAGENES_FUENTES/
og-image-*.png
*.webp

# ── Notas operacionales internas ─────────────────────────────
*!!.md
FULL-AUDIT-REPORT.md
ACTION-PLAN.md
LEARNING_LOG.md
MAINTENANCE.md
memoria_estado.md
to_fix_skill.md
learning.md
CONTI!!.md
stitch2elementor_audit_prompt.md
auditoria!!.md
actual!!.md
clean!!.md
continue!!.md

# ── Datos de cliente en manifest y SEO ───────────────────────
page_manifest.json
seo-report-*.html
seo_reaudit_*.html
seo_test_*.html

# ── Outputs generados (mantener estructura, ignorar contenido) ─
elementor_jsons/*
!elementor_jsons/README.md
exports/*
!exports/README.md
logs/*
!logs/README.md
assets_originales/*
!assets_originales/README.md

# ── Dependencias y build artifacts ───────────────────────────
node_modules/
*.log
scratch/
design-system/
output/

# ── Archivos de sistema ───────────────────────────────────────
.DS_Store
Thumbs.db
# Archivos locales de proyecto — NO commitear
screen_map.json
memoria_estado.md
logs/
exports/
mcp_config.json

# Mantener ejemplos
!screen_map.example.json
!page_manifest_example.json
!mcp_config.example.json
