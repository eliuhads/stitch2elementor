# Environment Configuration for stitch2elementor
# Copy this file to .env and fill in your values.

# === FTP Credentials (for Hybrid FTP+PHP injection) ===
FTP_HOST=ftp.yoursite.com
FTP_USER=your_ftp_user
FTP_PASS=your_ftp_password
FTP_REMOTE_DIR=/public_html/v9_json_payloads/

# === WordPress Base URL ===
WP_BASE_URL=https://yoursite.com

# === WordPress REST API Credentials ===
# Used by wp-api.js and MCP servers.
# Generate Application Passwords at: WP Admin → Users → Profile → Application Passwords
WORDPRESS_BASE_URL=https://yoursite.com
WORDPRESS_USERNAME=your_wp_user
WORDPRESS_APPLICATION_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Aliases (used by elementor-mcp)
WP_URL=https://yoursite.com
WP_APP_USER=your_wp_user
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# === PHP Injection Security Token ===
# All PHP scripts (create_hf_native.php, inject_all_pages.php, flush_cache.php)
# require this token via ?token= query parameter.
INJECT_SECRET=your_secret_token_here

# === Google Stitch API Key (for StitchMCP) ===
# X_GOOG_API_KEY=your_stitch_api_key
