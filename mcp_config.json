{
  "mcpServers": {
    "StitchMCP": {
      "serverUrl": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "${X_GOOG_API_KEY}"
      },
      "disabled": false
    },
    "wp-elementor-mcp": {
      "command": "wp-elementor-mcp",
      "args": [],
      "env": {
        "WORDPRESS_BASE_URL": "${WORDPRESS_BASE_URL}",
        "WORDPRESS_USERNAME": "${WORDPRESS_USERNAME}",
        "WORDPRESS_APPLICATION_PASSWORD": "${WORDPRESS_APPLICATION_PASSWORD}",
        "WP_MCP_MODE": "advanced"
      },
      "disabled": false
    },
    "elementor-mcp": {
      "command": "elementor-mcp",
      "args": [],
      "env": {
        "WP_URL": "${WP_URL}",
        "WP_APP_USER": "${WP_APP_USER}",
        "WP_APP_PASSWORD": "${WP_APP_PASSWORD}"
      },
      "disabled": false
    },
    "supabase": {
      "serverUrl": "https://mcp.supabase.com/mcp",
      "disabled": true
    }
  }
}